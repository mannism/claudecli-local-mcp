# --- Slack credentials (required) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# --- Socket Mode (optional, recommended for local dev — no tunnel needed) ---
# Set USE_SOCKET_MODE=true and provide an app-level token (starts with xapp-)
USE_SOCKET_MODE=false
SLACK_APP_TOKEN=xapp-...

# --- Claude mode ---
# true  = shell out to local `claude` CLI (no API key needed, local only)
# false = use Anthropic API (required for Railway/cloud deployment)
USE_CLI=true

# --- Anthropic API (only needed when USE_CLI=false) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Server ---
PORT=3000

# --- Gmail OAuth shared credentials (for /digest command) ---
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Enable Gmail API, create OAuth 2.0 Client ID (Web), add redirect URI: http://localhost:3000/oauth2callback
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...

# --- Gmail Account 1 ---
# Run: node scripts/gmail-auth.js --account 1   to generate the refresh token
GMAIL_ACCOUNT_1_EMAIL=dianaxismail@gmail.com
GMAIL_ACCOUNT_1_ALIAS=diana
GMAIL_ACCOUNT_1_REFRESH_TOKEN=...
GMAIL_ACCOUNT_1_DEFAULT_QUERY=        # optional raw Gmail query; blank = all unread

# --- Gmail Account 2 (optional) ---
# Run: node scripts/gmail-auth.js --account 2
GMAIL_ACCOUNT_2_EMAIL=
GMAIL_ACCOUNT_2_ALIAS=
GMAIL_ACCOUNT_2_REFRESH_TOKEN=
GMAIL_ACCOUNT_2_DEFAULT_QUERY=

# --- Gmail Account 3 (optional) ---
# Run: node scripts/gmail-auth.js --account 3
GMAIL_ACCOUNT_3_EMAIL=
GMAIL_ACCOUNT_3_ALIAS=
GMAIL_ACCOUNT_3_REFRESH_TOKEN=
GMAIL_ACCOUNT_3_DEFAULT_QUERY=

# --- OpenAI (for /digest and /inbox commands) ---
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.2

# --- File Inbox Paths (for /inbox command) ---
# OWNER_INBOX_PATH: folder where your team drops files for you to review  (/inbox scans this)
OWNER_INBOX_PATH=/path/to/owner-inbox
# TEAM_INBOX_PATH: folder where you put files to share with the team via Slack
TEAM_INBOX_PATH=/path/to/team-inbox

# --- Perplexity (optional) ---
PERPLEXITY_API_KEY=pplx-...
