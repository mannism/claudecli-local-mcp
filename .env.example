# --- Slack credentials (required) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# --- Socket Mode (optional, recommended for local dev — no tunnel needed) ---
# Set USE_SOCKET_MODE=true and provide an app-level token (starts with xapp-)
USE_SOCKET_MODE=false
SLACK_APP_TOKEN=xapp-...

# --- Claude mode ---
# true  = shell out to local `claude` CLI (no API key needed, local only)
# false = use Anthropic API (required for Railway/cloud deployment)
USE_CLI=true

# --- Anthropic API (only needed when USE_CLI=false) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Server ---
PORT=3000
